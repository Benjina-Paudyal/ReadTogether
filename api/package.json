{
  "name": "api",
  "private": true,
  "version": "1.0.0",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": "^20.12.1",
    "npm": "^10.5.0"
  },
  "scripts": {
    "dev": "nodemon src/index.mjs",
    "start": "node src/index.mjs",
    "format": "npx prettier . --write",
    "check": "npx eslint . --fix",
    "prepare": "husky",
    "lint": "eslint .",
    "migrate:make": "knex migrate:make --knexfile knexfile.js",
    "migrate:latest": "knex migrate:latest --knexfile knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.js",
    "migrate:status": "knex migrate:list --knexfile knexfile.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "mysql2": "^3.10.0",
    "pg": "^8.11.5",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.39.4",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5"
  }
}
